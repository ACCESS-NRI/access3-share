spack:
  specs:
  - access3 @git.{{ ref }}=stable configurations={{ all_configurations }}
  packages:
    access3-share:
      require:
        '@git.{{ ref }}=stable'
    intel-oneapi-compilers-classic:
      require:
      - '@{{ intel_compiler_version }}'
    all:
      require:
      - '%access_intel'
      - target={{ target }}
  concretizer:
    unify: false
  view: false
