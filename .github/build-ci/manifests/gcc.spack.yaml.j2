spack:
  specs:
  - access3 @git.{{ ref }}=stable configurations={{ all_configurations }}
  packages:
    access3-share:
      require:
        '@git.{{ ref }}=stable'
    gcc:
      require:
      - '@13.4.0'
    all:
      require:
      - '%access_gcc'
      - target={{ target }}
  concretizer:
    unify: false
  view: false
